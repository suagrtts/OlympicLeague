<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Methods"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/green_dark"
        android:layout_marginBottom="20dp" />

    <RadioGroup
        android:id="@+id/rgPaymentMethods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbBankTransfer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Bank Transfer"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:buttonTint="@color/green_dark" />

        <RadioButton
            android:id="@+id/rbGcash"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="GCash"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:buttonTint="@color/green_dark" />

        <RadioButton
            android:id="@+id/rbCrypto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Crypto Payment"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:buttonTint="@color/green_dark" />

        <RadioButton
            android:id="@+id/rbOthers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Others"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:buttonTint="@color/green_dark" />
    </RadioGroup>

    <EditText
        android:id="@+id/etOtherPayment"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_border"
        android:paddingHorizontal="16dp"
        android:hint="Please specify"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnCancelPayment"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btnSavePayment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/green_dark"
            android:text="Select"
            android:textColor="@color/white"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>